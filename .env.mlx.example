# ============================================================
# M3 36GB MLX Optimization Environment Variables
# ============================================================
# Copy to `.env.mlx` for local use, then source it:
#   cp .env.mlx.example .env.mlx
#   source .env.mlx
# ============================================================

# --- Ollama MLX Backend ---
export OLLAMA_MLX=1
export OLLAMA_METAL=1
export OLLAMA_MAX_LOADED_MODELS=1          # 메모리 안정성 — 1모델씩 로드
export OLLAMA_NUM_GPU=999                  # 모든 레이어 GPU 오프로드
export OLLAMA_NUM_PARALLEL=2               # 동시 요청 제한
export OLLAMA_FLASH_ATTENTION=1            # Flash Attention 활성화
export OLLAMA_MAX_QUEUE=4                  # 큐 제한

# --- Angella Harness Defaults ---
# setup.sh resolves actual lead/planner/worker models from the harness catalog.
# Optional overrides:
# export ANGELLA_HARNESS_PROFILE=default
# export ANGELLA_ENABLE_NVFP4_PREVIEW=1
# export ANGELLA_APFEL_BASE_URL=http://127.0.0.1:11435
# export ANGELLA_APFEL_MODEL=apple-foundationmodel

# --- Goose Safety ---
export GOOSE_MODE=smart_approve
export GOOSE_TELEMETRY_ENABLED=false

# --- Angella Paths ---
if [ -n "${BASH_SOURCE[0]:-}" ]; then
  _ANGELLA_ENV_SOURCE="${BASH_SOURCE[0]}"
elif [ -n "${ZSH_VERSION:-}" ]; then
  _ANGELLA_ENV_SOURCE="${(%):-%N}"
else
  _ANGELLA_ENV_SOURCE="$0"
fi

export ANGELLA_ROOT="${ANGELLA_ROOT:-$(cd "$(dirname "$_ANGELLA_ENV_SOURCE")" && pwd)}"

# --- Obsidian Auto-Log (fallback: $ANGELLA_ROOT/logs) ---
export OBSIDIAN_VAULT_PATH="${OBSIDIAN_VAULT_PATH:-$ANGELLA_ROOT/logs}"

unset _ANGELLA_ENV_SOURCE

# --- Telemetry Off ---
export GOOSE_DISABLE_TELEMETRY=1

# Gemini API Key
# 기존 값이 있으면 그대로 두세요.
# 예시:
# export GOOGLE_API_KEY=your_real_api_key
